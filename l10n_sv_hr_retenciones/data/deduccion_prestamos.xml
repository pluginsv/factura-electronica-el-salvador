<odoo>
    <data noupdate="1">

        <!-- Tipo de entrada: Calculo -->
        <record id="input_type_deduccion_prestamos" model="hr.payslip.input.type">
            <field name="name">Prestamos principal</field>
            <field name="code">PRESTAMOS</field>
            <field name="is_quantity">true</field>
            <field name="available_in_attachments">true</field>
            <field name="country_id" eval="False"/>
        </record>

        <!-- Crear regla salarial de deducciÃ³n de renta -->
        <record id="salary_rule_prestamos" model="hr.salary.rule">
            <field name="name">Prestamos</field>
            <field name="code">PRESTAMOS</field>
            <field name="sequence">140</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="struct_id" ref="l10n_sv_hr_retenciones.structure_incoe"/>
            <field name="condition_select">input</field>
            <field name="condition_other_input_id" ref="input_type_deduccion_prestamos"/>
            <field name="amount_select">input</field>
            <field name="input_type_id" ref="input_type_deduccion_prestamos"/>
            <field name="amount_other_input_id" ref="input_type_deduccion_prestamos"/>
            <field name="appears_on_payslip" eval="True"/>
        </record>

    </data>
</odoo>
