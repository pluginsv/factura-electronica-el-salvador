<odoo>

    <record id="view_anexo_mayores_search" model="ir.ui.view">
        <field name="name">account.move.anexo.mayores.search</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <search string="Buscar - Anexo Mayores 25,000">
                <field name="partner_id" string="Cliente"/>
                <field name="invoice_user_id" string="Vendedor"/>
                <field name="name" string="Número"/>

                <!-- Filtros de periodo -->
                <separator/>
                <filter name="filter_current_period" string="Periodo en curso"
                        domain="[('invoice_date','&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('invoice_date','&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_last_month" string="Mes pasado"
                        domain="[('invoice_date','&gt;=', (context_today() - relativedelta(months=1, day=1)).strftime('%Y-%m-%d')),
                                 ('invoice_date','&lt;=', (context_today() - relativedelta(months=1, day=31)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_previous_period" string="Periodo anterior"
                        domain="[('invoice_date','&gt;=', (context_today() - relativedelta(months=2, day=1)).strftime('%Y-%m-%d')),
                                 ('invoice_date','&lt;=', (context_today() - relativedelta(months=1, day=31)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_last_15_days" string="Últimos 15 días"
                        domain="[('invoice_date','&gt;=', (context_today() - relativedelta(days=15)).strftime('%Y-%m-%d'))]"/>

                <!-- Filtros de monto -->
                <separator/>
                <filter name="filter_highest_amounts" string="Montos más altos"
                        domain="[('amount_untaxed','&gt;', 0)]"/>

                <!-- Agrupaciones -->
                <group expand="0" string="Agrupar por">
                    <filter name="group_by_year" string="Año" context="{'group_by': 'invoice_year'}"/>
                    <filter name="group_by_semester" string="Semestre" context="{'group_by': 'invoice_semester'}"/>
                    <filter name="group_by_month" string="Mes" context="{'group_by': 'invoice_month'}"/>
                    <filter name="group_by_partner" string="Cliente" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_by_salesperson" string="Vendedor" context="{'group_by': 'invoice_user_id'}"/>
                    <filter name="group_by_tipo_documento" string="Tipo de documento" context="{'group_by': 'codigo_tipo_documento'}"/>
                </group>

                <!-- SearchPanel -->
                <searchpanel>
                    <field name="invoice_year_sel" select="one" enable_counters="1"/>
                    <field name="invoice_semester" select="one" enable_counters="1"/>
                    <field name="invoice_month_sel" select="one" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="view_report_account_move_daily_mayores_list" model="ir.ui.view">
        <field name="name">report.account.move.daily.mayores.list</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <list string="Facturas &gt; $25,000">
                <header>
                    <button name="action_download_csv_anexo" type="object" string="Descargar CSV" class="oe_highlight" display="always"/>
                </header>
                <field name="invoice_month"/>
                <field name="codigo_tipo_documento_cliente_display" string="Documento de identificación"/>
                <field name="documento_sujeto_excluido" string="Número documento identificación"/>
                <field name="razon_social" string="Nombre o razón social"/>
                <field name="invoice_date" string="Fecha de emisión"/>
                <field name="codigo_tipo_documento_display"/>
                <field name="hacienda_codigoGeneracion_identificacion" string="Número de documento"/>
                <field name="amount_untaxed" string="Monto de operación"/>
                <field name="amount_tax" string="IVA"/>
                <field name="invoice_year" string="Año"/>
                <field name="numero_anexo"/>
            </list>
        </field>
    </record>
</odoo>
