<odoo>

    <record id="view_report_resumen_vendedor_list" model="ir.ui.view">
        <field name="name">report.resumen.vendedor.list</field>
        <field name="model">report.resumen.vendedor</field>
        <field name="arch" type="xml">
            <list string="Resumen por Vendedor" create="false" edit="false" delete="false">
                <field name="period"/>
                <field name="invoice_user_id"/>
                <field name="team_id"/>
                <field name="invoice_count" sum="Facturas"/>
                <field name="total_invoiced" sum="Facturado"/>
                <field name="total_collected" sum="Cobrado"/>
                <field name="total_pending" sum="Pendiente"/>
                <field name="collection_rate" widget="percentage"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_report_resumen_vendedor_pivot" model="ir.ui.view">
        <field name="name">report.resumen.vendedor.pivot</field>
        <field name="model">report.resumen.vendedor</field>
        <field name="arch" type="xml">
            <pivot string="Resumen por Vendedor">
                <field name="invoice_user_id" type="row"/>
                <field name="period" type="col"/>
                <field name="total_invoiced" type="measure"/>
                <field name="total_collected" type="measure"/>
                <field name="total_pending" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_report_resumen_vendedor_graph" model="ir.ui.view">
        <field name="name">report.resumen.vendedor.graph</field>
        <field name="model">report.resumen.vendedor</field>
        <field name="arch" type="xml">
            <graph string="Resumen por Vendedor" type="bar">
                <field name="invoice_user_id"/>
                <field name="total_invoiced" type="measure"/>
                <field name="total_collected" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_report_resumen_vendedor_search" model="ir.ui.view">
        <field name="name">report.resumen.vendedor.search</field>
        <field name="model">report.resumen.vendedor</field>
        <field name="arch" type="xml">
            <search string="Buscar Resumen Vendedor">
                <field name="invoice_user_id" string="Vendedor"/>
                <field name="team_id" string="Equipo"/>
                <field name="period" string="Periodo"/>

                <group expand="0" string="Agrupar por">
                    <filter name="group_by_year" string="Año" context="{'group_by': 'invoice_year'}"/>
                    <filter name="group_by_month" string="Mes" context="{'group_by': 'invoice_month'}"/>
                    <filter name="group_by_period" string="Periodo" context="{'group_by': 'period'}"/>
                    <filter name="group_by_salesperson" string="Vendedor" context="{'group_by': 'invoice_user_id'}"/>
                    <filter name="group_by_team" string="Equipo de ventas" context="{'group_by': 'team_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_report_resumen_vendedor" model="ir.actions.act_window">
        <field name="name">Resumen por Vendedor</field>
        <field name="res_model">report.resumen.vendedor</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_report_resumen_vendedor_search"/>
    </record>

</odoo>
