<odoo>

    <record id="view_report_productos_vendidos_list" model="ir.ui.view">
        <field name="name">report.productos.vendidos.list</field>
        <field name="model">report.productos.vendidos</field>
        <field name="arch" type="xml">
            <list string="Productos más Vendidos" create="false" edit="false" delete="false">
                <field name="period"/>
                <field name="product_id"/>
                <field name="product_categ_id"/>
                <field name="quantity_sold" sum="Cantidad"/>
                <field name="total_revenue" sum="Ingreso"/>
                <field name="avg_unit_price"/>
                <field name="invoice_count" sum="Facturas"/>
                <field name="partner_count" sum="Clientes"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_report_productos_vendidos_pivot" model="ir.ui.view">
        <field name="name">report.productos.vendidos.pivot</field>
        <field name="model">report.productos.vendidos</field>
        <field name="arch" type="xml">
            <pivot string="Productos más Vendidos">
                <field name="product_id" type="row"/>
                <field name="period" type="col"/>
                <field name="quantity_sold" type="measure"/>
                <field name="total_revenue" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_report_productos_vendidos_graph" model="ir.ui.view">
        <field name="name">report.productos.vendidos.graph</field>
        <field name="model">report.productos.vendidos</field>
        <field name="arch" type="xml">
            <graph string="Productos más Vendidos" type="bar">
                <field name="product_id"/>
                <field name="total_revenue" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_report_productos_vendidos_search" model="ir.ui.view">
        <field name="name">report.productos.vendidos.search</field>
        <field name="model">report.productos.vendidos</field>
        <field name="arch" type="xml">
            <search string="Buscar Productos">
                <field name="product_id" string="Producto"/>
                <field name="product_categ_id" string="Categoría"/>
                <field name="period" string="Periodo"/>

                <group expand="0" string="Agrupar por">
                    <filter name="group_by_product" string="Producto" context="{'group_by': 'product_id'}"/>
                    <filter name="group_by_category" string="Categoría" context="{'group_by': 'product_categ_id'}"/>
                    <filter name="group_by_year" string="Año" context="{'group_by': 'invoice_year'}"/>
                    <filter name="group_by_month" string="Mes" context="{'group_by': 'invoice_month'}"/>
                    <filter name="group_by_period" string="Periodo" context="{'group_by': 'period'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_report_productos_vendidos" model="ir.actions.act_window">
        <field name="name">Productos más Vendidos</field>
        <field name="res_model">report.productos.vendidos</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_report_productos_vendidos_search"/>
    </record>

</odoo>
