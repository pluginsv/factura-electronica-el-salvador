<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_gran_contribuyente_warning" model="ir.ui.view">
        <field name="name">sale.order.gran.contribuyente.warning</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning"
                     role="alert"
                     invisible="not advertencia_gran_contribuyente">
                    <field name="advertencia_gran_contribuyente"
                           widget="html"
                           nolabel="1"/>
                </div>
            </xpath>

        </field>
    </record>
    <record id="view_account_move_gran_contribuyente_warning" model="ir.ui.view">
        <field name="name">account.move.gran.contribuyente.warning</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning"
                     role="alert"
                     invisible="not advertencia_gran_contribuyente_move">
                    <field name="advertencia_gran_contribuyente_move"
                           widget="html"
                           nolabel="1"/>
                </div>
            </xpath>

        </field>
    </record>
</odoo>