<odoo>

    <!-- ============================================================ -->
    <!--   SEARCH: Consumidor Final Agrupado                          -->
    <!-- ============================================================ -->
    <record id="view_consumidor_final_agrupado_search" model="ir.ui.view">
        <field name="name">report.account.move.consumidor.final.agrupado.search</field>
        <field name="model">report.account.move.consumidor.final.agrupado</field>
        <field name="arch" type="xml">
            <search string="Buscar - Consumidor Final">
                <!-- Filtros de periodo -->
                <separator/>
                <filter name="filter_current_period" string="Periodo en curso"
                        domain="[('invoice_date','&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('invoice_date','&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_last_month" string="Mes pasado"
                        domain="[('invoice_date','&gt;=', (context_today() - relativedelta(months=1, day=1)).strftime('%Y-%m-%d')),
                                 ('invoice_date','&lt;=', (context_today() - relativedelta(months=1, day=31)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_previous_period" string="Periodo anterior"
                        domain="[('invoice_date','&gt;=', (context_today() - relativedelta(months=2, day=1)).strftime('%Y-%m-%d')),
                                 ('invoice_date','&lt;=', (context_today() - relativedelta(months=1, day=31)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_last_15_days" string="Últimos 15 días"
                        domain="[('invoice_date','&gt;=', (context_today() - relativedelta(days=15)).strftime('%Y-%m-%d'))]"/>

                <!-- Filtros de monto -->
                <separator/>
                <filter name="filter_highest_amounts" string="Montos más altos"
                        domain="[('monto_total_operacion','&gt;', 0)]"/>

                <!-- Agrupaciones -->
                <group expand="0" string="Agrupar por">
                    <filter name="group_by_year" string="Año" context="{'group_by': 'invoice_year_agrupado'}"/>
                    <filter name="group_by_semester" string="Semestre" context="{'group_by': 'invoice_semester_agrupado'}"/>
                    <filter name="group_by_month" string="Mes" context="{'group_by': 'invoice_month_agrupado'}"/>
                    <filter name="group_by_tipo_documento" string="Tipo de documento" context="{'group_by': 'codigo_tipo_documento_codigo'}"/>
                    <filter name="group_by_clase_documento" string="Clase de documento" context="{'group_by': 'clase_documento_codigo'}"/>
                </group>

                <searchpanel>
                    <field name="invoice_year_sel" select="one" enable_counters="1"/>
                    <field name="invoice_month_sel" select="one" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

