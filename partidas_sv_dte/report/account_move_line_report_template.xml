<odoo>
    <template id="report_move_line_template">
        <t t-call="web.html_container">
            <t t-call-assets="web.assets_pdf" t-js="false"/>
            <div class="page">
                <meta charset="UTF-8"/>
                <style>@charset "UTF-8"; * { font-size: 0.8rem !important; letter-spacing: 0.09em !important; }
                    @font-face { font-family: 'Inter'; src: url('/invoice_sv_dte/static/src/fonts/Inter-Regular.ttf')
                    format('truetype'); } body { font-family: 'Inter', Arial, Helvetica, sans-serif; line-height: 100%;
                    } table, th, tr, td { border: 1px solid #000 !important; padding: 0.6rem !important; } .header,
                    .footer, #wrapwrap > header, #wrapwrap > footer { display: none !important; }
                </style>
                <div style="position: relative; width: 100%; margin-bottom: 20px; min-height: 100px;">
                    <t t-if="company.logo">
                        <div style="position: absolute; left: 0; top: 0;">
                            <img id="logo" t-att-src="'data:image/png;base64,%s' % company.logo_web.decode('utf-8')"
                                 style="max-height: 85px; width: auto;"/>
                        </div>
                    </t>
                    <div style="text-align: center; width: 100%;">
                        <div style="font-size:14px; font-weight:700;">
                            <t t-esc="company.name"/>
                        </div>
                        <div style="font-size:11px; font-weight:600; margin-top:2px;">
                            Fecha:
                            <t t-esc="date_report"/>
                        </div>
                        <div style="font-size:10px; margin-top:2px;">(Valores expresados en Dólares de Estados Unidos de
                            América)
                        </div>
                        <div style="margin:0; margin-top:20px;">
                            <p style="font-weight:700;" t-esc="tipo_label"/>
                        </div>
                        <div style="margin:0; font-size:12px; font-weight:700; margin-bottom:10px;"
                             t-esc="correlativo"/>
                    </div>
                </div>
                <table style="width:100%; border-collapse:collapse; font-size:10px; table-layout:fixed;">
                    <thead>
                        <tr style="font-weight:700; background-color: #EAEAEA;">
                            <th style="width:8%; padding:3px 4px; text-align:center;">Codigo</th>
                            <th style="width:37%; padding:3px 4px; text-align:center;">Nombre</th>
                            <th style="width:9%; padding:3px 4px; text-align:center;">Monto</th>
                            <th style="width:9%; padding:3px 4px; text-align:center;">SubTotal</th>
                            <th style="width:9%; padding:3px 4px; text-align:center;">Parcial</th>
                            <th style="width:9%; padding:3px 4px; text-align:center;">Debe</th>
                            <th style="width:9%; padding:3px 4px; text-align:center;">Haber</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="rows" t-as="row">
                            <t t-if="row['type'] == 'parent_main'">
                                <tr style="background-color: #D5E5EC;">
                                    <td style="padding:3px 4px; font-weight:700;">
                                        <t t-esc="row['code']"/>
                                    </td>
                                    <td t-attf-style="padding:3px 4px 3px #{4 + ((row.get('level', 0) or 0) * 12)}px; font-weight:700; text-transform:uppercase;">
                                        <t t-esc="row['name']"/>
                                    </td>
                                    <td/>
                                    <td/>
                                    <td/>
                                    <td style="padding:3px 4px; text-align:right; font-weight:700;">
                                        <t t-if="row['total_debit']">
                                            <t t-esc="'%.2f' % row['total_debit']"/>
                                        </t>
                                    </td>
                                    <td style="padding:3px 4px; text-align:right; font-weight:700;">
                                        <t t-if="row['total_credit']">
                                            <t t-esc="'%.2f' % row['total_credit']"/>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                            <t t-if="row['type'] == 'parent_partial'">
                                <tr style="background-color: #D5E5EC;">
                                    <td style="padding:3px 4px; font-weight:700;">
                                        <t t-esc="row['code']"/>
                                    </td>
                                    <td t-attf-style="padding:3px 4px 3px #{4 + ((row.get('level', 0) or 0) * 12)}px; font-weight:700; text-transform:uppercase;">
                                        <t t-esc="row['name']"/>
                                    </td>
                                    <td/>
                                    <td/>
                                    <td style="padding:3px 4px; text-align:right; font-weight:700;">
                                        <t t-if="row.get('partial_amount')">
                                            <t t-esc="'%.2f' % row['partial_amount']"/>
                                        </t>
                                    </td>
                                    <td style="padding:3px 4px; text-align:right; font-weight:700;">
                                        <!--                                        <t t-if="row['total_debit']">-->
                                        <!--                                            <t t-esc="'%.2f' % row['total_debit']"/>-->
                                        <!--                                        </t>-->
                                    </td>
                                    <td style="padding:3px 4px; text-align:right; font-weight:700;">
                                        <!--                                        <t t-if="row['total_credit']">-->
                                        <!--                                            <t t-esc="'%.2f' % row['total_credit']"/>-->
                                        <!--                                        </t>-->
                                    </td>
                                </tr>
                            </t>

                            <t t-if="row['type'] == 'account_total'">
                                <tr style="border-bottom:none!important;">
                                    <td style="padding:3px 4px; font-weight:700; border-bottom:none!important;">
                                        <t t-esc="row['account_code']"/>
                                    </td>
                                    <td style="padding:3px 4px; font-weight:700; text-transform:uppercase; border-bottom:none!important;">
                                        <t t-esc="row['account_name']"/>
                                    </td>
                                    <td style="border-bottom:none!important;"/>
                                    <td style="padding:3px 4px; text-align:right; font-weight:700; border-bottom:none!important;">
                                        <t t-if="row['subtotal_cuenta']">
                                            <t t-esc="'%.2f' % row['subtotal_cuenta']"/>
                                        </t>
                                    </td>
                                    <td style="border-bottom:none!important;"/>
                                    <td style="padding:3px 4px; text-align:right; font-weight:700; border-bottom:none!important;">
                                        <t t-if="row['subtotal_debit']">
<!--                                            <t t-esc="'%.2f' % row['subtotal_debit']"/>-->
                                        </t>
                                    </td>
                                    <td style="padding:3px 4px; text-align:right; font-weight:700; border-bottom:none!important;">
                                        <t t-if="row['subtotal_credit']">
<!--                                            <t t-esc="'%.2f' % row['subtotal_credit']"/>-->
                                        </t>
                                    </td>
                                </tr>
                            </t>

                            <t t-if="row['type'] == 'detail'">
                                <tr style="border-bottom:none!important; border-top:none!important;">
                                    <td style="padding:3px 4px; font-weight:700; vertical-align:top; border-top:none!important; border-bottom:none!important;">
                                        <t t-if="row['is_first']">
                                        </t>
                                    </td>

                                    <td style="padding:3px 4px; vertical-align:center; border-top:none!important; border-bottom:none!important;">
                                        <div style="font-size:10px;">
                                            <t t-esc="row['date']"/>
                                            |
                                            <t t-esc="row['journal_code']"/>
                                        </div>
                                        <div style="font-size:10px; word-break:break-word;">
                                            <t t-if="row['sello_recepcion']">
                                                <t t-esc="row['sello_recepcion']"/>
                                                |
                                            </t>
                                            <t t-if="row['partner']">
                                                <t t-esc="row['partner']"/>
                                                |
                                            </t>
<!--                                            <t t-if="row['label']">-->
<!--                                                <t t-esc="row['label']"/>-->
<!--                                                |-->
<!--                                            </t>-->
                                            <t t-if="row['label']">
                                                <t t-esc="row['ref']"/>
                                            </t>
                                        </div>
                                    </td>

                                    <td style="padding:3px 4px; text-align:right; vertical-align:center; border-top:none!important; border-bottom:none!important;">
                                        <t t-esc="'%.2f' % row['amount']"/>
                                    </td>

                                    <td style="padding:3px 4px; border-top:none!important; border-bottom:none!important;"/>
                                    <td style="padding:3px 4px; border-top:none!important; border-bottom:none!important;"/>
                                    <td style="padding:3px 4px; border-top:none!important; border-bottom:none!important;"/>
                                    <td style="padding:3px 4px; border-top:none!important; border-bottom:none!important;"/>
                                </tr>
                            </t>

                            <t t-if="row['type'] == 'grand_total'">
                                <tr style="border-top: 1px solid #000;">
                                    <td colspan="5"
                                        style="padding:3px 6px; text-align:right; font-weight:900; font-size:12px;">
                                        Total:
                                    </td>
                                    <td style="padding:3px 4px; text-align:right; font-weight:900; font-size:12px;">
                                        <t t-esc="'%.2f' % row['total_debit']"/>
                                    </td>
                                    <td style="padding:3px 4px; text-align:right; font-weight:900; font-size:12px;">
                                        <t t-esc="'%.2f' % row['total_credit']"/>
                                    </td>
                                </tr>
                            </t>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <record id="paperformat_partidas" model="report.paperformat">
        <field name="name">Comprobante de Credito Fiscal</field>
        <field name="default" eval="True"/>
        <field name="format">Letter</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">12</field>
        <field name="margin_bottom">12</field>
        <field name="margin_left">18</field>
        <field name="margin_right">18</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">35</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_account_move_line" model="ir.actions.report">
        <field name="name">Reporte Partidas Contables</field>
        <field name="model">account.move.line.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">partidas_sv_dte.report_move_line_template</field>
        <field name="report_file">partidas_sv_dte.report_move_line_template</field>
        <field name="paperformat_id" ref="paperformat_partidas"/>
    </record>
</odoo>