<odoo>
    <record id="view_account_move_line_report_wizard" model="ir.ui.view">
        <field name="name">account.move.line.report.wizard.form</field>
        <field name="model">account.move.line.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Reporte de Partidas Contables">
                <sheet>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="partida_type"/>
                            <field name="journal_ids" widget="many2many_tags" options="{'no_create': True}" invisible="partida_type != 'diario'"/>
                            <field name="report_date"/>
                            <field name="correlativo" readonly="1" invisible="1"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="target_move"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_report" string="Imprimir PDF" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_account_move_line_report_wizard_from_lines" model="ir.actions.act_window">
        <field name="name">Imprimir Partidas</field>
        <field name="res_model">account.move.line.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move_line"/>
        <field name="binding_view_types">list</field>
    </record>

    <record id="action_account_move_report_wizard_from_moves" model="ir.actions.act_window">
        <field name="name">Imprimir Partidas</field>
        <field name="res_model">account.move.line.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list,form</field>
    </record>
</odoo>
