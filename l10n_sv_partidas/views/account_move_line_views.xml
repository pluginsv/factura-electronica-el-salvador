<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Botón en vista lista de apuntes contables -->
    <record id="view_move_line_list_inherit_sv" model="ir.ui.view">
        <field name="name">account.move.line.list.inherit.sv.partidas</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button name="%(l10n_sv_partidas.action_account_move_line_report_wizard_from_lines)d"
                            string="📄 Imprimir Partidas"
                            type="action"
                            display="always"
                            class="btn-primary"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
