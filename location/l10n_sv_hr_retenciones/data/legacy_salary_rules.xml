            <field name="name">Legacy: IPSFA Empleador (innuffe)</field>
        </record>

        <record id="isss_regla_employee_innuffe" model="hr.salary.rule" forcecreate="False">
            <field name="name">Legacy: ISSS Empleado (innuffe)</field>
        </record>

        <record id="isss_empleador_regla_innuffe" model="hr.salary.rule" forcecreate="False">
            <field name="name">Legacy: ISSS Empleador (innuffe)</field>
        </record>

        <record id="salary_rule_bancos_innuffe" model="hr.salary.rule" forcecreate="False">
