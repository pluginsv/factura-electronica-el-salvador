<odoo>

    <record id="view_move_form_inherit_skip_mh_post" model="ir.ui.view">
        <field name="name">account.move.form.skip.mh.post</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//button[@name='action_post']" position="after">

                <button name="action_post_without_mh"
                        string="Validar Documento"
                        type="object"
                        class="btn-secondary"
                        invisible="1"/>
            </xpath>

        </field>
    </record>

</odoo>