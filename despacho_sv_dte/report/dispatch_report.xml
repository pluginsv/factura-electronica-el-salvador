<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="paperformat_dispatch_reception" model="report.paperformat">
            <field name="name">Recepción de ruta</field>
            <field name="default" eval="True"/>
            <field name="format">Letter</field>
            <field name="orientation">Portrait</field>
            <field name="dpi">90</field>
        </record>

         <record id="paperformat_dispatch_carga_ruta" model="report.paperformat">
            <field name="name">Carga de ruta</field>
            <field name="default" eval="True"/>
            <field name="format">Letter</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">15</field>
            <field name="margin_right">15</field>
            <field name="orientation">Portrait</field>
            <field name="dpi">90</field>
        </record>

         <record id="action_report_montacarguista" model="ir.actions.report">
            <field name="name">Reporte montacarguista</field>
            <field name="model">dispatch.route</field>
            <field name="paperformat_id" ref="paperformat_dispatch_carga_ruta"/>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">despacho_sv_dte.report_montacarguista_template</field>
            <field name="report_file">despacho_sv_dte.report_montacarguista_template</field>
            <field name="print_report_name">'Reporte Montacarguista - ' + object.name</field>
            <field name="binding_model_id" ref="model_dispatch_route"/>
            <field name="binding_type">report</field>
        </record>

        <record id="action_report_recepcion_ruta" model="ir.actions.report">
            <field name="name">Recepción de Ruta</field>
            <field name="model">dispatch.route.reception</field>
            <field name="paperformat_id" ref="paperformat_dispatch_carga_ruta"/>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">despacho_sv_dte.report_recepcion_ruta_template</field>
            <field name="report_file">despacho_sv_dte.report_recepcion_ruta_template</field>
            <field name="print_report_name">'Recepcion_Ruta_%s' % (object.name or '')</field>
            <field name="binding_model_id" ref="model_dispatch_route_reception"/>
            <field name="binding_type">report</field>
        </record>

        <record id="action_report_carga_ruta" model="ir.actions.report">
            <field name="name">Reporte de carga de Ruta</field>
            <field name="model">dispatch.route</field>
            <field name="paperformat_id" ref="paperformat_dispatch_carga_ruta"/>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">despacho_sv_dte.report_carga_de_ruta_template</field>
            <field name="report_file">despacho_sv_dte.report_carga_de_ruta_template</field>
            <field name="binding_model_id" ref="model_dispatch_route"/>
            <field name="binding_type">report</field>
        </record>

        <record id="action_report_dispatch_delivery_analysis_pdf" model="ir.actions.report">
            <field name="name">Estados de Ruta (PDF)</field>
            <field name="model">dispatch.delivery.analysis</field>
            <field name="paperformat_id" ref="paperformat_dispatch_carga_ruta"/>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">despacho_sv_dte.report_dispatch_delivery_analysis_pdf</field>
            <field name="report_file">despacho_sv_dte.report_dispatch_delivery_analysis_pdf</field>
            <field name="print_report_name">'Estados de Ruta - %s' % (object and object[0].create_date or '')
            </field>
        </record>
</odoo>