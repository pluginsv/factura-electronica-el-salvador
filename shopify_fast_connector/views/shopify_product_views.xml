<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shopify_product_tree" model="ir.ui.view">
        <field name="name">shopify.product.tree</field>
        <field name="model">shopify.product</field>
        <field name="arch" type="xml">
            <tree string="Productos Shopify">
                <field name="shopify_title"/>
                <field name="shopify_sku"/>
                <field name="shopify_price"/>
                <field name="shopify_inventory_qty"/>
                <field name="product_id"/>
                <field name="instance_id"/>
                <field name="synced" widget="boolean"/>
                <field name="last_sync"/>
            </tree>
        </field>
    </record>

    <record id="view_shopify_product_form" model="ir.ui.view">
        <field name="name">shopify.product.form</field>
        <field name="model">shopify.product</field>
        <field name="arch" type="xml">
            <form string="Producto Shopify">
                <sheet>
                    <group>
                        <group string="Shopify">
                            <field name="shopify_title"/>
                            <field name="shopify_id"/>
                            <field name="shopify_variant_id"/>
                            <field name="shopify_sku"/>
                            <field name="shopify_price"/>
                            <field name="shopify_inventory_qty"/>
                            <field name="shopify_image_url" widget="url"/>
                        </group>
                        <group string="Odoo">
                            <field name="instance_id"/>
                            <field name="product_id"/>
                            <field name="synced"/>
                            <field name="last_sync"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_product" model="ir.actions.act_window">
        <field name="name">Productos Shopify</field>
        <field name="res_model">shopify.product</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
