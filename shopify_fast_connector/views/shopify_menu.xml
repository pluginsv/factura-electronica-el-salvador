<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Menu Principal -->
    <menuitem id="menu_shopify_root"
              name="Shopify"
              web_icon="shopify_fast_connector,static/description/icon.png"
              sequence="45"/>

    <!-- Submenu Dashboard -->
    <menuitem id="menu_shopify_dashboard"
              name="Tiendas"
              parent="menu_shopify_root"
              action="action_shopify_instance"
              sequence="10"/>

    <menuitem id="menu_shopify_setup"
              name="Configurar Nueva Tienda"
              parent="menu_shopify_root"
              action="action_shopify_setup_wizard"
              sequence="15"/>

    <!-- Submenu Datos -->
    <menuitem id="menu_shopify_data"
              name="Datos"
              parent="menu_shopify_root"
              sequence="20"/>

    <menuitem id="menu_shopify_orders"
              name="Pedidos"
              parent="menu_shopify_data"
              action="action_shopify_order"
              sequence="10"/>

    <menuitem id="menu_shopify_products"
              name="Productos"
              parent="menu_shopify_data"
              action="action_shopify_product"
              sequence="20"/>

    <menuitem id="menu_shopify_customers"
              name="Clientes"
              parent="menu_shopify_data"
              action="action_shopify_customer"
              sequence="30"/>

    <!-- Submenu Configuracion -->
    <menuitem id="menu_shopify_config"
              name="Configuracion"
              parent="menu_shopify_root"
              sequence="90"/>

    <menuitem id="menu_shopify_logs"
              name="Logs"
              parent="menu_shopify_config"
              action="action_shopify_log"
              sequence="10"/>
</odoo>
